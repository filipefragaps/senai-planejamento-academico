# ── Ambiente ──────────────────────────────────────────────────────────────────
APP_ENV=production

# ── Banco de dados ─────────────────────────────────────────────────────────────
# Railway fornece automaticamente como DATABASE_URL
# Formatos aceitos: postgres:// | postgresql:// | postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/banco

# ── Segurança ──────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-de-pelo-menos-32-caracteres

# ── Admin inicial (criado automaticamente na 1ª inicialização) ─────────────────
ADMIN_EMAIL=admin@suainstituicao.com.br
ADMIN_SENHA=SenhaSuperSegura123!

# ── CORS: domínio do frontend no Vercel ───────────────────────────────────────
CORS_ORIGINS=https://seu-projeto.vercel.app,http://localhost:3000

# ── Anthropic (IA) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
